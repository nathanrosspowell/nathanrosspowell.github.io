---
title: Blog
root: true
---
<h1>Posts</h1>

<h2>blog----</h2>
{{#each blog}}
    {{#each pages}}
        <hr/>
        <hr/>
        This: {{ this }}
        Title: {{data.title}}
        {{data.posted}}
        {{data.blog}}
        <hr/>
        {{ basename }}
        <hr/>
{{#each data.content}}
  {{{md this}}}
{{/each}}
      
    {{/each}}
{{/each}}

<h2>error----</h2>
{{#each error}}
    {{#each this.pages}}
        <hr/>
        {{ src }}
    {{/each}}
{{/each}}


<h2>root----</h2>
{{#each root}}
    {{#each this.pages}}
        <hr/>
        {{ src }}
    {{/each}}
{{/each}}


