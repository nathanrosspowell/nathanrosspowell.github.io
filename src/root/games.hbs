---
title: Games
root: true
---
<h1>Games</h1>
{{#each games}}
    {{#each pages}}
        <hr/>
        <h2>
            <a href="{{ basename }}.html">{{data.title}}</a>
        </h2>
        <p>
            Posted:{{data.posted}}
        </p>
        {{#if data.intro }}
            <p>
                {{{ md data.intro }}}
            <p>
            <a href="{{ basename }}.html">Read more...</a>
        {{/if}}
    {{/each}}
{{/each}}

