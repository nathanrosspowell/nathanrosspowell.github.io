---
title: Home
root: true
heading: 'Welcome!'
lead: Welcome to my website!
intro: 'src/content/index-jumbotron.md'
content: 'src/content/index-body.md'
---
<div class="jumbotron">
  <h1>{{ heading }}</h1>
  <p>
     {{{ md intro }}}
  </p>
</div>
<p>
    {{{ md content }}}
</p>

<div class="row">
    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h4>Instagram</h4>
            </div>
            <div class="panel-body">
                <!-- INSTANSIVE WIDGET --><script src="http://instansive.com/widget/js/instansive.js"></script><iframe src="http://instansive.com/widgets/ud3fa40b31edf1460ef46e6f8dcea675.html" scrolling="no" allowtransparency="true" class="instansive-widget" style="width: 100%; border: 0; overflow: hidden;"></iframe>

                <hr/>
                <a class="btn btn-custom btn-large" href="http://instagram.com/{{ social.instagram}}">
                    Follow me
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h4>Twitter</h4>
            </div>
            <div class="panel-body">
                <a class="twitter-timeline" href="https://twitter.com/{{ social.twitter }}" data-widget-id="389099304515690496">Tweets by @{{ social.twitter }}</a>
                <script>!function(d,s,id){var js,fjs=d.getElementsByTagName(s)[0],p=/^http:/.test(d.location)?'http':'https';if(!d.getElementById(id)){js=d.createElement(s);js.id=id;js.src=p+"://platform.twitter.com/widgets.js";fjs.parentNode.insertBefore(js,fjs);}}(document,"script","twitter-wjs");</script>

                <hr/>
                <a class="btn btn-custom btn-large" href="http://twitter.com/{{ social.twitter }}">
                    Follow me
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h4>Last.fm</h4>
            </div>
            <div class="panel-body">
                <div>
                    <a href="http://www.last.fm/user/{{social.lastfm}}/?chartstyle=minimalLight">
                        <img 
                            src="http://tapmusic.net/lastfm/collage.php?user={{social.lastfm}}&type=7day&size=2x8&caption=true" 
                            border="0"
                            class="img-responsive" 
                        />
                    </a>
                </div>
                
                <hr/>
                <a class="btn btn-custom btn-large" href="http://www.last.fm/user/{{social.lastfm}}">
                    Follow me
                </a>
            </div>
        </div>
    </div>
</div>

<div class="panel panel-default">
    <div class="panel-heading">
        Recent Comments
    </div>
    <div class="panel-body">
        <div id="recentcomments" class="dsq-widget">
            <script 
                type="text/javascript" 
                src="http://nathanrosspowell.disqus.com/recent_comments_widget.js?num_items=5&hide_avatars=0&avatar_size=32&excerpt_length=200">
            </script>
        </div>
    </div>
</div>
