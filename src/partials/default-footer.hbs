---
component: footer
date: new Date()
---
    <footer class="footer">
      <div class="container">
        <br/>
        <div id="footer-social-container" class="container">
            <ul id="footer-social-links">
                {{> social-media }}
            </ul>
        </div>
        <div class="container">
            <p class="text-muted">
                &copy; {{ site.author }} {{formatDate site.date "%Y"}}.
                This website was last statically updated: {{formatDate site.date "%Y/%m/%d %H:%M:%S"}}.
            </p>
        </div>
      </div>
    </footer>
<!-- jQuery (necessary for Bootstrap's JavaScript plugins) -->
    <script src="https://code.jquery.com/jquery.js"></script>
    <!-- Include all compiled plugins (below), or include individual files as needed -->
    <script src="{{assets}}/js/bootstrap.min.js"></script>
  </body>
</html>
